{
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "unpublished.nattlua",
  "search.exclude": {
    "goluwa/nattlua": true
  },
  "runOnSave.commands": [
    {
      "globMatch": "**/*",
      "command": "cd ${workspaceFolder} && luajit .vscode/run_on_save.lua '${fileRelative}'",
      "runIn": "vscode"
    }
  ]
}
